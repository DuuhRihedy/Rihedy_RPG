generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Personagens (Fichas) ──────────

model Character {
  id               String   @id @default(cuid())
  name             String
  edition          String   @default("3.5") // "3.5" | "5e"
  race             String?
  class            String?  // Pode ser multiclass: "Fighter 5 / Wizard 3"
  level            Int      @default(1)
  alignment        String?
  background       String?  // usado no 5e
  deity            String?  // usado no 3.5
  gender           String?
  age              String?
  height           String?
  weight           String?
  eyes             String?
  hair             String?
  skin             String?
  imageUrl         String?
  status           String   @default("active") // active, retired, dead

  // Atributos base
  str              Int      @default(10)
  dex              Int      @default(10)
  con              Int      @default(10)
  intl             Int      @default(10)
  wis              Int      @default(10)
  cha              Int      @default(10)

  // Combate
  maxHp            Int      @default(8)
  currentHp        Int      @default(8)
  tempHp           Int      @default(0)
  ac               Int      @default(10)
  touchAc          Int?     // 3.5
  flatFootedAc     Int?     // 3.5
  initiative       Int      @default(0)
  speed            Int      @default(30)

  // D&D 3.5 específico
  bab              Int?     // Base Attack Bonus
  grapple          Int?
  fortSave         Int?
  refSave          Int?
  willSave         Int?
  spellResistance  Int?
  damageReduction  String?

  // D&D 5e específico
  proficiencyBonus Int?
  hitDice          String?  // "8d10"
  hitDiceRemaining Int?
  deathSaveSuccesses Int @default(0)
  deathSaveFailures  Int @default(0)
  inspiration      Boolean  @default(false)

  // JSON fields (flexible para ambas edições)
  savingThrows     String?  // JSON: 5e saves { str: { proficient, value }, ... }
  skills           String?  // JSON: 3.5 ranks ou 5e proficiencies
  feats            String?  // JSON: [{ name, description, source }]
  features         String?  // JSON: [{ name, description, level, source }]
  equipment        String?  // JSON: [{ name, quantity, weight, equipped, description }]
  weapons          String?  // JSON: [{ name, attackBonus, damage, type, properties }]
  armor            String?  // JSON: { name, ac, type, equipped }
  spellcasting     String?  // JSON: { ability, dc, attackBonus, slots, known/prepared }
  spells           String?  // JSON: { 0: [...], 1: [...], ... } by level
  proficiencies    String?  // JSON: { armor, weapons, tools, languages }
  currency         String?  // JSON: { cp, sp, gp, pp }
  traits           String?  // JSON: { personality, ideals, bonds, flaws } (5e)
  notes            String?  // Notas livres do jogador

  // Relações
  createdById      String?
  createdBy        User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  campaignId       String?
  campaign         Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([edition])
  @@index([campaignId])
}

// ── Usuários ──────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user") // "admin" | "user"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campaigns Campaign[]
  npcs      Npc[]
  characters Character[]
}

// ── Campanhas ──────────────────────

model Campaign {
  id          String   @id @default(cuid())
  name        String
  description String?
  edition     String   @default("3.5")
  status      String   @default("active")
  imageUrl    String?
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions    Session[]
  npcs        CampaignNpc[]
  notes       Note[]
  arcs        StoryArc[]
  maps        Map[]
  documents   Document[]
  links       Link[]
  chapters    Chapter[]
  characters  Character[]
}

// ── Sessões ────────────────────────

model Session {
  id          String   @id @default(cuid())
  number      Int
  title       String?
  date        DateTime?
  notes       String?
  aiRecap     String?
  durationMin Int?
  createdAt   DateTime @default(now())

  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  events      Event[]
  npcsPresent SessionNpc[]
}

// ── NPCs ───────────────────────────

model Npc {
  id          String   @id @default(cuid())
  name        String
  race        String?
  class       String?
  level       Int?
  alignment   String?
  description String?
  backstory   String?
  gmNotes     String?
  imageUrl    String?
  status      String   @default("alive")
  type        String   @default("neutral")
  edition     String   @default("3.5")
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attributes  NpcAttributes?
  items       Item[]
  relationsFrom Relation[] @relation("relationOrigin")
  relationsTo   Relation[] @relation("relationTarget")
  campaigns   CampaignNpc[]
  sessions    SessionNpc[]
}

model NpcAttributes {
  id    String @id @default(cuid())
  str   Int    @default(10)
  dex   Int    @default(10)
  con   Int    @default(10)
  intl  Int    @default(10)
  wis   Int    @default(10)
  cha   Int    @default(10)
  hp    Int    @default(10)
  ac    Int    @default(10)
  npcId String @unique
  npc   Npc    @relation(fields: [npcId], references: [id], onDelete: Cascade)
}

// ── Itens ──────────────────────────

model Item {
  id          String  @id @default(cuid())
  name        String
  type        String
  description String?
  weight      Float?
  value       String?
  magical     Boolean @default(false)
  imageUrl    String?

  npcId       String?
  npc         Npc?    @relation(fields: [npcId], references: [id], onDelete: SetNull)
}

// ── Relações entre NPCs ────────────

model Relation {
  id          String @id @default(cuid())
  type        String
  description String?

  originId    String
  origin      Npc    @relation("relationOrigin", fields: [originId], references: [id], onDelete: Cascade)
  targetId    String
  target      Npc    @relation("relationTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

// ── Tabelas de Junção ──────────────

model CampaignNpc {
  npcId      String
  npc        Npc      @relation(fields: [npcId], references: [id], onDelete: Cascade)
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@id([npcId, campaignId])
}

model SessionNpc {
  npcId     String
  npc       Npc     @relation(fields: [npcId], references: [id], onDelete: Cascade)
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@id([npcId, sessionId])
}

// ── Notas ──────────────────────────

model Note {
  id         String   @id @default(cuid())
  title      String
  content    String
  private    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// ── Eventos ────────────────────────

model Event {
  id          String @id @default(cuid())
  description String
  type        String

  sessionId   String
  session     Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ── Arcos Narrativos ───────────────

model StoryArc {
  id          String @id @default(cuid())
  title       String
  description String?
  status      String @default("active")

  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// ── Capítulos da História ─────────

model Chapter {
  id          String   @id @default(cuid())
  title       String
  content     String   @default("")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// ── Documentos ────────────────────

model Document {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("notas") // historia, ficha, aventura, notas, outro
  content     String   // texto extraído
  sourceFile  String?  // nome do arquivo original
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// ── Vínculos entre entidades ──────

model Link {
  id        String   @id @default(cuid())
  fromType  String   // npc, item, document, map, note
  fromId    String
  toType    String
  toId      String
  label     String?
  createdAt DateTime @default(now())

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([fromType, fromId])
  @@index([toType, toId])
}

// ── Mapas ─────────────────────────

model Map {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("other") // world, city, dungeon, village, other
  description String?
  imageUrl    String
  createdAt   DateTime @default(now())

  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
}

// ── Histórico de Chat IA ───────────

model ChatHistory {
  id          String   @id @default(cuid())
  question    String
  answer      String
  context     String?
  tokensUsed  Int?
  createdAt   DateTime @default(now())
}

// ── Uso da API de IA ────────────────

model ApiUsage {
  id          String   @id @default(cuid())
  source      String   // "chat", "chapters", "documents", etc
  provider    String   @default("gemini")
  model       String?
  tokensUsed  Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// ── Configuração do Provider de IA ──

model AiProviderConfig {
  id          String   @id @default("singleton")
  provider    String   @default("gemini")   // "gemini" | "groq" | "openrouter"
  apiKey      String?                        // key única (legado, opcional)
  model       String?
  fallback    Boolean  @default(true)
  temperature Float    @default(0.7)
  maxTokens   Int      @default(4096)
  updatedAt   DateTime @updatedAt
}

// ── Pool de API Keys (rotação) ──────

model AiApiKey {
  id          String    @id @default(cuid())
  provider    String    // "gemini" | "groq" | "openrouter"
  label       String    // nome para identificar ("Gemini Key 1", "Projeto RPG", etc)
  apiKey      String
  active      Boolean   @default(true)
  blockedUntil DateTime? // quando atingiu rate limit, desbloqueia automaticamente
  usageToday  Int       @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([provider, active])
}

// ══════════════════════════════════════
// ── ACERVO SRD ───────────────────────
// ══════════════════════════════════════

model SrdSpell {
  id            String  @id @default(cuid())
  index         String  @unique
  name          String
  namePtBr      String? // nome traduzido PT-BR
  edition       String  @default("5e")
  level         Int
  school        String
  castingTime   String
  range         String
  components    String  // "V, S, M"
  material      String?
  materialPtBr  String? // material traduzido PT-BR
  duration      String
  concentration Boolean @default(false)
  ritual        Boolean @default(false)
  description   String  // texto completo EN
  descriptionPtBr String? // descrição traduzida PT-BR
  higherLevel   String? // texto higher level EN
  higherLevelPtBr String? // higher level traduzido PT-BR
  classes       String  // "Wizard, Sorcerer" — join para filtro
  damageType    String?
  areaOfEffect  String? // JSON: { type, size }
  source        String  @default("SRD")
}

model SrdMonster {
  id              String  @id @default(cuid())
  index           String  @unique
  name            String
  namePtBr        String? // nome traduzido PT-BR
  edition         String  @default("5e")
  size            String
  type            String
  alignment       String?
  armorClass      Int
  hitPoints       Int
  hitDice         String
  speed           String  // JSON: { walk, fly, swim, ... }
  str             Int
  dex             Int
  con             Int
  intl            Int
  wis             Int
  cha             Int
  challengeRating Float
  xp              Int
  languages       String?
  senses          String? // JSON
  proficiencies   String? // JSON
  damageImmunities    String?
  damageResistances   String?
  damageVulnerabilities String?
  conditionImmunities String?
  specialAbilities    String? // JSON EN
  specialAbilitiesPtBr String? // JSON PT-BR
  actions              String? // JSON EN
  actionsPtBr          String? // JSON PT-BR
  legendaryActions     String? // JSON EN
  legendaryActionsPtBr String? // JSON PT-BR
  reactions            String? // JSON EN
  reactionsPtBr        String? // JSON PT-BR
  imageUrl         String?
  source           String @default("SRD")
}

model SrdClass {
  id            String @id @default(cuid())
  index         String @unique
  name          String
  namePtBr      String? // nome traduzido PT-BR
  edition       String @default("5e")
  hitDie        Int
  proficiencies String? // JSON
  savingThrows  String? // "INT, WIS"
  spellcasting  String? // JSON
  subclasses    String? // JSON
  classLevels   String? // JSON
  source        String @default("SRD")
}

model SrdFeat {
  id              String @id @default(cuid())
  index           String @unique
  name            String
  namePtBr        String? // nome traduzido PT-BR
  edition         String @default("5e")
  description     String
  descriptionPtBr String? // descrição traduzida PT-BR
  prerequisites   String? // JSON
  source          String @default("SRD")
}

model SrdEquipment {
  id              String  @id @default(cuid())
  index           String  @unique
  name            String
  namePtBr        String? // nome traduzido PT-BR
  edition         String  @default("5e")
  category        String
  cost            String? // "25 gp"
  weight          Float?
  description     String?
  descriptionPtBr String? // descrição traduzida PT-BR
  damage          String? // JSON: { dice, type }
  armorClass      String? // JSON
  properties      String? // JSON
  source          String  @default("SRD")
}

model SrdMagicItem {
  id              String  @id @default(cuid())
  index           String  @unique
  name            String
  namePtBr        String? // nome traduzido PT-BR
  edition         String  @default("5e")
  category        String
  rarity          String
  description     String
  descriptionPtBr String? // descrição traduzida PT-BR
  requiresAttunement Boolean @default(false)
  source          String @default("SRD")
}

// ── Raças ──────────────────────────

model SrdRace {
  id              String  @id @default(cuid())
  index           String  @unique
  name            String
  namePtBr        String?
  edition         String  @default("5e")
  speed           Int
  abilityBonuses  String? // JSON: [{ name, bonus }]
  alignment       String?
  age             String?
  size            String?
  sizeDescription String?
  languages       String? // JSON
  traits          String? // JSON: [{ index, name }]
  subraces        String? // JSON
  proficiencies   String? // JSON
  source          String  @default("SRD")
}

model SrdSubrace {
  id              String  @id @default(cuid())
  index           String  @unique
  name            String
  namePtBr        String?
  edition         String  @default("5e")
  raceIndex       String
  description     String?
  abilityBonuses  String? // JSON
  traits          String? // JSON
  proficiencies   String? // JSON
  source          String  @default("SRD")
}

// ── Subclasses ─────────────────────

model SrdSubclass {
  id              String  @id @default(cuid())
  index           String  @unique
  name            String
  namePtBr        String?
  edition         String  @default("5e")
  classIndex      String
  description     String?
  descriptionPtBr String?
  features        String? // JSON
  spells          String? // JSON
  source          String  @default("SRD")
}

// ── Features de Classe ─────────────

model SrdFeature {
  id              String  @id @default(cuid())
  index           String  @unique
  name            String
  namePtBr        String?
  edition         String  @default("5e")
  classIndex      String?
  subclassIndex   String?
  level           Int
  description     String
  descriptionPtBr String?
  prerequisites   String? // JSON
  source          String  @default("SRD")
}

// ── Condições ──────────────────────

model SrdCondition {
  id              String  @id @default(cuid())
  index           String  @unique
  name            String
  namePtBr        String?
  edition         String  @default("5e")
  description     String
  descriptionPtBr String?
  source          String  @default("SRD")
}

// ── Skills ─────────────────────────

model SrdSkill {
  id              String  @id @default(cuid())
  index           String  @unique
  name            String
  namePtBr        String?
  edition         String  @default("5e")
  abilityScore    String  // "DEX", "WIS", etc.
  description     String
  descriptionPtBr String?
  source          String  @default("SRD")
}

// ── Traits (Raciais) ───────────────

model SrdTrait {
  id              String  @id @default(cuid())
  index           String  @unique
  name            String
  namePtBr        String?
  edition         String  @default("5e")
  races           String? // JSON: [{ index, name }]
  subraces        String? // JSON
  description     String
  descriptionPtBr String?
  proficiencies   String? // JSON
  source          String  @default("SRD")
}

// ── Idiomas ────────────────────────

model SrdLanguage {
  id              String  @id @default(cuid())
  index           String  @unique
  name            String
  namePtBr        String?
  edition         String  @default("5e")
  type            String  // "Standard" or "Exotic"
  typicalSpeakers String? // "Humans, Halflings, ..."
  script          String? // "Common", "Elvish", etc.
  source          String  @default("SRD")
}

// ── Regras da Casa ─────────────────────
model HouseRule {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  icon        String   @default("📜")
  category    String   @default("geral") // combate, roleplay, exploração, magia, geral
  summary     String?  // resumo curto para o card
  content     String   // rich-text HTML (Blocksmith)
  pinned      Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
